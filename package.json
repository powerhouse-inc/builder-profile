{
  "name": "@powerhousedao/builder-profile",
  "description": "Builder profile document model",
  "version": "1.0.8",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/powerhouse-inc/builder-profile"
  },
  "type": "module",
  "files": [
    "/dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/browser/index.d.ts",
      "browser": "./dist/browser/index.js",
      "node": "./dist/node/index.mjs"
    },
    "./document-models": {
      "types": "./dist/browser/document-models/index.d.ts",
      "browser": "./dist/browser/document-models/index.js",
      "node": "./dist/node/document-models/index.mjs"
    },
    "./document-models/*": {
      "types": "./dist/browser/document-models/*/index.d.ts",
      "browser": "./dist/browser/document-models/*/index.js",
      "node": "./dist/node/document-models/*/index.mjs"
    },
    "./editors": {
      "types": "./dist/browser/editors/index.d.ts",
      "browser": "./dist/browser/editors/index.js",
      "node": "./dist/node/editors/index.mjs"
    },
    "./editors/*": {
      "types": "./dist/browser/editors/*/module.d.ts",
      "browser": "./dist/browser/editors/*/module.js",
      "node": "./dist/node/editors/*/module.mjs"
    },
    "./subgraphs": {
      "types": "./dist/browser/subgraphs/index.d.ts",
      "browser": "./dist/browser/subgraphs/index.js",
      "node": "./dist/node/subgraphs/index.mjs"
    },
    "./processors": {
      "types": "./dist/browser/processors/index.d.ts",
      "browser": "./dist/browser/processors/index.js",
      "node": "./dist/node/processors/index.mjs"
    },
    "./manifest": "./dist/powerhouse.manifest.json",
    "./style.css": "./dist/style.css"
  },
  "scripts": {
    "build": "ph-cli build",
    "copy-assets": "cp -r editors/builder-profile/assets dist/editors/builder-profile/assets",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint --config eslint.config.js --cache",
    "lint:fix": "npm run lint -- --fix",
    "tsc": "tsc",
    "tsc:watch": "tsc --watch",
    "tailwind": "bunx tailwindcss -i ./style.css -o ./dist/style.css",
    "prepublishOnly": "npm run build",
    "check-circular-imports": "npx dpdm -T ./index.ts",
    "generate": "ph-cli generate",
    "connect": "ph-cli connect",
    "reactor": "ph-cli reactor",
    "service": "ph-cli service",
    "vetra": "ph-cli vetra",
    "service-startup": "bash ./node_modules/@powerhousedao/ph-cli/dist/scripts/service-startup.sh",
    "service-unstartup": "bash ./node_modules/@powerhousedao/ph-cli/dist/scripts/service-unstartup.sh",
    "migrate": "ph-cli migrate"
  },
  "dependencies": {
    "@powerhousedao/analytics-engine-core": "6.0.0-dev.210",
    "@powerhousedao/builder-tools": "6.0.0-dev.210",
    "@powerhousedao/common": "6.0.0-dev.210",
    "@powerhousedao/connect": "6.0.0-dev.210",
    "@powerhousedao/design-system": "6.0.0-dev.210",
    "@powerhousedao/document-engineering": "1.40.2",
    "@powerhousedao/reactor-api": "6.0.0-dev.210",
    "@powerhousedao/reactor-browser": "6.0.0-dev.210",
    "@powerhousedao/shared": "6.0.0-dev.210",
    "@powerhousedao/vetra": "6.0.0-dev.210",
    "@uiw/react-md-editor": "^4.0.11",
    "document-model": "6.0.0-dev.210",
    "error": "^10.4.0",
    "graphql": "16.12.0",
    "graphql-tag": "^2.12.6",
    "lucide-react": "^0.556.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "rehype-slug": "^6.0.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@electric-sql/pglite": "0.3.15",
    "@electric-sql/pglite-tools": "0.2.20",
    "@eslint/js": "^9.38.0",
    "@powerhousedao/codegen": "6.0.0-dev.210",
    "@powerhousedao/config": "6.0.0-dev.210",
    "@powerhousedao/ph-cli": "6.0.0-dev.210",
    "@powerhousedao/reactor": "6.0.0-dev.210",
    "@powerhousedao/reactor-local": "^5.3.6",
    "@powerhousedao/scalars": "^2.0.1",
    "@powerhousedao/switchboard": "6.0.0-dev.210",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@tailwindcss/cli": "^4.1.18",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.9.2",
    "@types/react": "^19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "document-drive": "^5.3.6",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.4.0",
    "package-manager-detector": "^0.2.8",
    "pm2": "^5.4.3",
    "semantic-release": "^25.0.2",
    "tailwindcss": "^4.1.16",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vite": "8.0.8",
    "vite-plugin-node-polyfills": "^0.24.0",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.1"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "release": {
    "branches": [
      "main",
      {
        "name": "staging",
        "prerelease": "staging"
      },
      {
        "name": "dev",
        "prerelease": "dev"
      }
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "releaseRules": [
            {
              "type": "chore",
              "release": "patch"
            },
            {
              "type": "ci",
              "release": "patch"
            },
            {
              "type": "docs",
              "release": "patch"
            },
            {
              "type": "refactor",
              "release": "patch"
            },
            {
              "type": "style",
              "release": "patch"
            },
            {
              "type": "test",
              "release": "patch"
            }
          ]
        }
      ],
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      [
        "@semantic-release/npm",
        {
          "npmPublish": false
        }
      ],
      "@semantic-release/github",
      "@semantic-release/git"
    ]
  },
  "readme": "ERROR: No README data found!",
  "sideEffects": false
}
